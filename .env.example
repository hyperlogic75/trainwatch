# ─── 서버 ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ─── 데이터베이스 (Railway PostgreSQL 자동 주입) ─────────────
DATABASE_URL=postgresql://user:password@host:5432/trainwatch

# ─── 인증 ───────────────────────────────────────────────────
# 반드시 랜덤 256비트 이상으로 변경
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── Firebase Admin SDK ──────────────────────────────────────
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# JSON 파일 전체를 한 줄로 직렬화: jq -c . firebase-key.json
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Google OAuth ────────────────────────────────────────────
# Google Cloud Console → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=https://trainwatch.app,exp://localhost:8081
